{
  "sourceBranch": "jamstack-builder",
  "baseBranch": "main",
  "allowMappings": [
    {
      "source": "src/_assets/CSS/styles.css",
      "target": "CSS/styles.css",
      "reason": "portable runtime stylesheet"
    },
    {
      "source": "src/_assets/CSS/header-nav.css",
      "target": "CSS/header-nav.css",
      "reason": "portable runtime nav/header stylesheet"
    },
    {
      "source": "src/_assets/scripts/header-nav.js",
      "target": "scripts/header-nav.js",
      "reason": "portable runtime nav interaction logic"
    }
  ],
  "blockedPatterns": [
    ".eleventy.js",
    "config.yml",
    "package.json",
    "package-lock.json",
    "content/**",
    "scripts/cms/**",
    "src/admin/**",
    "static/admin/**",
    "src/_data/**",
    "src/_includes/**",
    "src/_layouts/**",
    "src/**/*.njk",
    "src/_assets/CSS/*.scss",
    "src/_assets/CSS/_*.scss"
  ],
  "manualReviewPatterns": [
    "src/_includes/header.html",
    "src/_data/nav.json",
    "src/index.njk",
    "src/important-update/index.njk"
  ]
}
